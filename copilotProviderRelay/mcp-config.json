{
    "tools": [
        {
            "name": "copilot_provider_status",
            "title": "Copilot Provider Relay Status",
            "description": "Report the active provider backend catalog and relay mode. Provider reachability checks belong to the provider agents themselves.",
            "command": "/usr/local/bin/node",
            "args": [
                "/code/tools/status.mjs"
            ],
            "cwd": "/code",
            "inputSchema": {}
        },
        {
            "name": "copilot_provider_list_backends",
            "title": "List Copilot Provider Backends",
            "description": "Return the static catalog of provider backends owned by this repository and their default Ploinky agent ids.",
            "command": "/usr/local/bin/node",
            "args": [
                "/code/tools/list-backends.mjs"
            ],
            "cwd": "/code",
            "inputSchema": {}
        },
        {
            "name": "copilot_provider_task_submit",
            "title": "Submit Copilot Provider Task",
            "description": "Forward a semantic Copilot provider task to its provider agent and return the backend's natural-language result.",
            "command": "/usr/local/bin/node",
            "args": [
                "/code/tools/submit-task.mjs"
            ],
            "cwd": "/code",
            "timeoutMs": 450000,
            "inputSchema": {
                "backend": {
                    "type": "string",
                    "optional": false,
                    "description": "Provider backend id, such as open-interpreter."
                },
                "prompt": {
                    "type": "string",
                    "optional": false,
                    "maxLength": 16000
                },
                "provider": {
                    "type": "string",
                    "optional": true,
                    "maxLength": 100,
                    "description": "Provider id for interactive browser-use tasks, such as chatgpt or gemini."
                },
                "resources": {
                    "type": "array",
                    "optional": true,
                    "items": {
                        "type": "object",
                        "additionalProperties": true
                    }
                },
                "paths": {
                    "type": "array",
                    "optional": true,
                    "items": {
                        "type": "string"
                    }
                },
                "origin": {
                    "type": "object",
                    "optional": true,
                    "additionalProperties": true
                },
                "timeoutMs": {
                    "type": "number",
                    "optional": true,
                    "min": 1000,
                    "max": 120000
                }
            }
        }
    ]
}
