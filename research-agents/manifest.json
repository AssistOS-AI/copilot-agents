{
    "container": "node:20-alpine",
    "lite-sandbox": true,
    "about": "Explicit deployment bundle for the copilot-agents research suite. Enables the research-relay (researchRelay) and the openInterpreterAgent provider. Provider agents execute research tasks locally in their own containers based on the shared bwrap-runner image; this bundle must not enable basic/bwrap-runner.",
    "env": [
        "PLOINKY_WORKSPACE_ROOT"
    ],
    "enable": [
        "researchRelay global",
        "openInterpreterAgent global no-wait"
    ],
    "profiles": {
        "default": {
            "enable": [
                "researchRelay global",
                "openInterpreterAgent global no-wait"
            ]
        },
        "dev": {
            "enable": [
                "researchRelay global",
                "openInterpreterAgent global no-wait"
            ]
        },
        "qa": {
            "enable": [
                "researchRelay global",
                "openInterpreterAgent global no-wait"
            ]
        },
        "prod": {
            "enable": [
                "researchRelay global",
                "openInterpreterAgent global no-wait"
            ]
        }
    }
}
