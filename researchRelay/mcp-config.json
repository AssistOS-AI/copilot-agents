{
    "tools": [
        {
            "name": "research_relay_status",
            "title": "Research Relay Status",
            "description": "Report the active research backend catalog and relay mode. Provider reachability checks belong to the provider agents themselves.",
            "command": "/usr/local/bin/node",
            "args": [
                "/code/tools/status.mjs"
            ],
            "cwd": "/code",
            "inputSchema": {}
        },
        {
            "name": "research_relay_list_backends",
            "title": "List Research Backends",
            "description": "Return the static catalog of research backends owned by this repository and their default Ploinky agent ids.",
            "command": "/usr/local/bin/node",
            "args": [
                "/code/tools/list-backends.mjs"
            ],
            "cwd": "/code",
            "inputSchema": {}
        },
        {
            "name": "research_relay_dispatch",
            "title": "Plan Research Relay Dispatch",
            "description": "Compatibility helper for older launch integrations. New callers should use research_task_submit.",
            "command": "/usr/local/bin/node",
            "args": [
                "/code/tools/dispatch.mjs"
            ],
            "cwd": "/code",
            "inputSchema": {
                "backend": {
                    "type": "string",
                    "optional": false
                },
                "working_directory": {
                    "type": "string",
                    "optional": true
                },
                "skill_root": {
                    "type": "string",
                    "optional": true
                }
            }
        },
        {
            "name": "research_task_submit",
            "title": "Submit Research Task",
            "description": "Forward a semantic Copilot research task to its provider agent and return the backend's natural-language result.",
            "command": "/usr/local/bin/node",
            "args": [
                "/code/tools/submit-task.mjs"
            ],
            "cwd": "/code",
            "timeoutMs": 450000,
            "inputSchema": {
                "backend": {
                    "type": "string",
                    "optional": false,
                    "description": "Research backend id, such as open-interpreter."
                },
                "prompt": {
                    "type": "string",
                    "optional": false,
                    "maxLength": 16000
                },
                "resources": {
                    "type": "array",
                    "optional": true,
                    "items": {
                        "type": "object",
                        "additionalProperties": true
                    }
                },
                "paths": {
                    "type": "array",
                    "optional": true,
                    "items": {
                        "type": "string"
                    }
                },
                "origin": {
                    "type": "object",
                    "optional": true,
                    "additionalProperties": true
                },
                "timeoutMs": {
                    "type": "number",
                    "optional": true,
                    "min": 1000,
                    "max": 120000
                }
            }
        }
    ]
}
