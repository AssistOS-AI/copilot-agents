{
    "container": "assistos/bwrap-runner:node24-python-bookworm",
    "about": "Open Interpreter provider agent. Prepares its own runtime under /data/research-runtimes/open-interpreter/<version>/ inside the provider container and executes research tasks in a local bwrap sandbox started inside the same container. Does not call basic/bwrap-runner.",
    "containerSecurity": {
        "privileged": true
    },
    "agent": "/usr/local/bin/node /opt/bwrap-runner/bin/healthcheck.mjs && sh /Agent/server/AgentServer.sh",
    "readiness": {
        "protocol": "mcp"
    },
    "health": {
        "readiness": {
            "script": "healthcheck.sh",
            "interval": 5,
            "timeout": 10,
            "failureThreshold": 12
        }
    },
    "env": [
        "PLOINKY_WORKSPACE_ROOT",
        "PLOINKY_ROUTER_URL",
        "OI_RUNTIME_ROOT",
        "OI_RUNTIME_AUTO_PREPARE",
        "OI_PREPARE_PYTHON",
        "SOUL_GATEWAY_API_KEY",
        "OPEN_INTERPRETER_MODEL",
        "OPEN_INTERPRETER_API_BASE",
        "OPEN_INTERPRETER_CONTEXT_WINDOW",
        "OPEN_INTERPRETER_MAX_TOKENS",
        "OPEN_INTERPRETER_OFFLINE",
        "OPEN_INTERPRETER_LOCAL"
    ],
    "profiles": {
        "default": {
            "env": {
                "DISABLE_TELEMETRY": "true",
                "ANONYMIZED_TELEMETRY": "false",
                "SOUL_GATEWAY_API_KEY": {
                    "name": "SOUL_GATEWAY_API_KEY"
                },
                "OPEN_INTERPRETER_OFFLINE": "true",
                "OI_RUNTIME_ROOT": "/data/research-runtimes",
                "OI_RUNTIME_AUTO_PREPARE": "true",
                "OI_PREPARE_PYTHON": "/usr/bin/python3"
            }
        }
    },
    "volumes": {
        ".ploinky/data/openInterpreterAgent": "/data"
    }
}
