{
    "container": "docker.io/assistos/bwrap-runner:node24-python-bookworm",
    "lite-sandbox": true,
    "about": "GPTResearcher agent. Runs GPT Researcher through the Python package and exposes research through a Ploinky MCP tool.",
    "readiness": {
        "protocol": "mcp"
    },
    "profiles": {
        "default": {
            "install": "sh /code/scripts/install-gpt-researcher.sh"
        }
    },
    "env": [
        "OPENAI_API_KEY",
        "TAVILY_API_KEY",
        "ANTHROPIC_API_KEY",
        "GROQ_API_KEY",
        "OPENROUTER_API_KEY",
        "DEEPSEEK_API_KEY",
        "XAI_API_KEY",
        "MISTRAL_API_KEY",
        "GOOGLE_API_KEY"
    ],
    "ideSettings": [
        {
            "key": "gpt-researcher-settings",
            "label": "GPTResearcher",
            "scope": "workspace",
            "pluginKey": "GPTResearcher/gpt-researcher-settings",
            "settingsComponent": "gpt-researcher-settings",
            "adminOnly": false
        }
    ]
}
